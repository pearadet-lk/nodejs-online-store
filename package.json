{
  "name": "nodejs-online-store",
  "private": true,
  "scripts": {
    "dev": "turbo run dev --concurrency=15",
    "dev:backend": "turbo run dev --concurrency=15 --filter=\"@online-store/*\" --filter=\"!@online-store/angular\"",
    "dev:frontend": "turbo run dev --filter=@online-store/angular",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}
