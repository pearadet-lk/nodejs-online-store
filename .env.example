# JWT (must match across Gateway and UserService)
AUTH_JWT_ISSUER=online-store
AUTH_JWT_AUDIENCE=online-store-clients
AUTH_JWT_SIGNING_KEY=dev-super-secret-signing-key-min-32-chars
AUTH_ACCESS_TOKEN_MINUTES=15
AUTH_REFRESH_TOKEN_DAYS=7

# Optional PostgreSQL (services fall back to in-memory when unset)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/online_store
